generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NHÂN VIÊN & TÀI KHOẢN ───────────────────────────────────────────────────

model NhanVien {
  maNV        String   @id @db.VarChar(10)
  hoTen       String   @db.VarChar(100)
  gioiTinh    String   @db.VarChar(5)   // "Nam" | "Nu"
  ngaySinh    DateTime @db.Date
  soDienThoai String   @db.VarChar(15)
  trangThai   Int      @default(1)       // 1: đang làm | 0: nghỉ việc

  taiKhoan        TaiKhoan[]
  yeuCauThue      YeuCauThue[]
  phieuCoc        PhieuCoc[]
  hopDong         HopDong[]
  phieuThu        PhieuThu[]
  bienBanBanGiao  BienBanBanGiao[]
  bienBanTraPhong BienBanTraPhong[]
  thanhLyHD       ThanhLyHD[]

  @@map("NhanVien")
}

model TaiKhoan {
  maTK        String   @id @db.VarChar(10)
  maNV        String   @db.VarChar(10)
  tenDangNhap String   @unique @db.VarChar(50)
  matKhau     String   @db.VarChar(255)
  vaiTro      String   @db.VarChar(20)  // "admin" | "sale" | "quanly" | "ketoan"
  email       String?  @db.VarChar(100)
  trangThai   Int      @default(1)

  nhanVien NhanVien @relation(fields: [maNV], references: [maNV])

  @@map("TaiKhoan")
}

// ─── CHI NHÁNH ────────────────────────────────────────────────────────────────

model ChiNhanh {
  maCN    String @id @db.VarChar(10)
  tenCN   String @db.VarChar(100)
  diaChi  String @db.VarChar(255)
  soDT    String @db.VarChar(15)

  phong    Phong[]
  phieuCoc PhieuCoc[]

  @@map("ChiNhanh")
}

// ─── KHÁCH HÀNG ───────────────────────────────────────────────────────────────

model KhachHang {
  maKH        String   @id @db.VarChar(10)
  hoTen       String   @db.VarChar(100)
  gioiTinh    String   @db.VarChar(5)
  ngaySinh    DateTime @db.Date
  cccd        String   @unique @db.VarChar(20)
  soDienThoai String   @db.VarChar(15)
  email       String?  @db.VarChar(100)
  quocTich    String   @default("Việt Nam") @db.VarChar(50)
  trangThai   Int      @default(1)           // 1: đang thuê | 0: đã rời

  yeuCauThue     YeuCauThue[]
  phieuCoc       PhieuCoc[]
  thanhVien      ThanhVien[]

  @@map("KhachHang")
}

// ─── PHÒNG & GIƯỜNG ───────────────────────────────────────────────────────────

model LoaiPhong {
  maLoai  String @id @db.VarChar(10)
  tenLoai String @db.VarChar(50)   // "Phòng đơn" | "Phòng đôi" | "Phòng ở ghép"
  moTa    String? @db.Text

  phong Phong[]

  @@map("LoaiPhong")
}

model Phong {
  maPhong      String @id @db.VarChar(10)
  tenPhong     String @db.VarChar(50)
  maCN         String @db.VarChar(10)
  maLoai       String @db.VarChar(10)
  sucChua      Int                         // số giường tối đa
  gioiTinhPhong String @db.VarChar(10)    // "Nam" | "Nu" | "Chung"
  giaThue      Decimal @db.Decimal(12, 0) // giá/giường/tháng
  trangThai    String @db.VarChar(20)      // "Trong" | "DaThue" | "DaCoc" | "BaoDuong"

  chiNhanh  ChiNhanh  @relation(fields: [maCN], references: [maCN])
  loaiPhong LoaiPhong @relation(fields: [maLoai], references: [maLoai])
  giuong    Giuong[]

  @@map("Phong")
}

model Giuong {
  maGiuong  String @id @db.VarChar(10)
  maPhong   String @db.VarChar(10)
  tenGiuong String @db.VarChar(50)
  trangThai String @db.VarChar(20)  // "Trong" | "DaThue" | "DaCoc"

  phong              Phong               @relation(fields: [maPhong], references: [maPhong])
  chiTietPhieuCoc    ChiTietPhieuCoc[]
  thanhVien          ThanhVien[]
  chiTietBanGiao     ChiTietBanGiao[]

  @@map("Giuong")
}

// ─── YÊU CẦU THUÊ & LỊCH HẸN ─────────────────────────────────────────────────

model YeuCauThue {
  maYCT       String   @id @db.VarChar(10)
  maKH        String   @db.VarChar(10)
  maNV        String   @db.VarChar(10)
  ngayYC      DateTime @db.Date
  soNguoi     Int
  gioiTinh    String   @db.VarChar(5)
  khuVuc      String?  @db.VarChar(100)
  loaiPhong   String?  @db.VarChar(50)
  mucGia      Decimal? @db.Decimal(12, 0)
  ngayVaoO    DateTime @db.Date
  thoiHanThue Int                          // số tháng
  trangThai   String   @db.VarChar(20)     // "ChoDuyet" | "DaHen" | "DaCoc" | "Huy"
  ghiChu      String?  @db.Text

  khachHang KhachHang @relation(fields: [maKH], references: [maKH])
  nhanVien  NhanVien  @relation(fields: [maNV], references: [maNV])
  lichHen   LichHen[]

  @@map("YeuCauThue")
}

model LichHen {
  maLH      String   @id @db.VarChar(10)
  maYCT     String   @db.VarChar(10)
  ngayHen   DateTime @db.Date
  gioHen    String   @db.VarChar(10)
  trangThai String   @db.VarChar(20)  // "ChoXacNhan" | "DaHen" | "HoanThanh" | "Huy"
  ghiChu    String?  @db.Text

  yeuCauThue YeuCauThue @relation(fields: [maYCT], references: [maYCT])

  @@map("LichHen")
}

// ─── PHIẾU CỌC ────────────────────────────────────────────────────────────────

model PhieuCoc {
  maPC          String   @id @db.VarChar(10)
  maKH          String   @db.VarChar(10)
  maNV          String   @db.VarChar(10)
  maCN          String   @db.VarChar(10)
  ngayCoc       DateTime @db.Timestamp()
  tienCoc       Decimal  @db.Decimal(12, 0)
  trangThai     String   @db.VarChar(20)   // "ChoThanhToan" | "DaThanhToan" | "TuDongHuy" | "HuyThuCong"
  hanThanhToan  DateTime @db.Timestamp()

  khachHang        KhachHang         @relation(fields: [maKH], references: [maKH])
  nhanVien         NhanVien          @relation(fields: [maNV], references: [maNV])
  chiNhanh         ChiNhanh          @relation(fields: [maCN], references: [maCN])
  chiTietPhieuCoc  ChiTietPhieuCoc[]
  hopDong          HopDong[]

  @@map("PhieuCoc")
}

model ChiTietPhieuCoc {
  maPC     String @db.VarChar(10)
  maGiuong String @db.VarChar(10)

  phieuCoc PhieuCoc @relation(fields: [maPC], references: [maPC])
  giuong   Giuong   @relation(fields: [maGiuong], references: [maGiuong])

  @@id([maPC, maGiuong])
  @@map("ChiTietPhieuCoc")
}

// ─── HỢP ĐỒNG & THÀNH VIÊN ───────────────────────────────────────────────────

model HopDong {
  maHD         String   @id @db.VarChar(10)
  maPC         String   @db.VarChar(10)
  maNV         String   @db.VarChar(10)
  ngayKy       DateTime @db.Date
  ngayBatDau   DateTime @db.Date
  ngayKetThuc  DateTime @db.Date
  kyThanhToan  Int                          // số tháng/kỳ
  trangThai    String   @db.VarChar(20)     // "DangHieuLuc" | "HetHan" | "DaThanhLy"
  anhHD        String?  @db.Text    

  phieuCoc         PhieuCoc         @relation(fields: [maPC], references: [maPC])
  nhanVien         NhanVien         @relation(fields: [maNV], references: [maNV])
  thanhVien        ThanhVien[]
  phieuThu         PhieuThu[]
  bienBanBanGiao   BienBanBanGiao[]
  bienBanTraPhong  BienBanTraPhong[]

  @@map("HopDong")
}

model ThanhVien {
  maTV      String @id @db.VarChar(10)
  maHD      String @db.VarChar(10)
  maKH      String @db.VarChar(10)
  maGiuong  String @db.VarChar(10)
  trangThai Int    @default(1)  // 1: đang ở | 0: đã rời

  hopDong   HopDong   @relation(fields: [maHD], references: [maHD])
  khachHang KhachHang @relation(fields: [maKH], references: [maKH])
  giuong    Giuong    @relation(fields: [maGiuong], references: [maGiuong])

  @@map("ThanhVien")
}

// ─── DỊCH VỤ & PHIẾU THU ─────────────────────────────────────────────────────

model DichVu {
  maDV       String  @id @db.VarChar(10)
  tenDV      String  @db.VarChar(100)  // "Điện" | "Nước" | "Wifi" | "Gửi xe"
  donViTinh  String  @db.VarChar(20)   // "kWh" | "m3" | "tháng" | "xe/tháng"
  donGia     Decimal @db.Decimal(12, 0)

  chiTietPhieuThu ChiTietPhieuThu[]

  @@map("DichVu")
}

model PhieuThu {
  maPT     String   @id @db.VarChar(10)
  maHD     String   @db.VarChar(10)
  maNV     String   @db.VarChar(10)
  ngayThu  DateTime @db.Date
  tongTien Decimal  @db.Decimal(12, 0)
  loaiThu  String   @db.VarChar(30)   // "TienThueKyDau" | "TienDichVu" | "TienPhat"
  ghiChu   String?  @db.Text

  hopDong         HopDong           @relation(fields: [maHD], references: [maHD])
  nhanVien        NhanVien          @relation(fields: [maNV], references: [maNV])
  chiTietPhieuThu ChiTietPhieuThu[]

  @@map("PhieuThu")
}

model ChiTietPhieuThu {
  maPT      String  @db.VarChar(10)
  maDV      String  @db.VarChar(10)
  soLuong   Decimal @db.Decimal(10, 2)
  donGia    Decimal @db.Decimal(12, 0)
  thanhTien Decimal @db.Decimal(12, 0)

  phieuThu PhieuThu @relation(fields: [maPT], references: [maPT])
  dichVu   DichVu   @relation(fields: [maDV], references: [maDV])

  @@id([maPT, maDV])
  @@map("ChiTietPhieuThu")
}

// ─── TÀI SẢN & BIÊN BẢN BÀN GIAO ────────────────────────────────────────────

model TaiSan {
  maTS   String  @id @db.VarChar(10)
  tenTS  String  @db.VarChar(100)  // "Giường", "Nệm", "Tủ", "Thẻ từ", "Điều hoà"
  loaiTS String  @db.VarChar(50)
  moTa   String? @db.Text

  chiTietBanGiao ChiTietBanGiao[]
  khauTru        KhauTru[]

  @@map("TaiSan")
}

model BienBanBanGiao {
  maBBBG       String   @id @db.VarChar(10)
  maHD         String   @db.VarChar(10)
  maNV         String   @db.VarChar(10)
  ngayBanGiao  DateTime @db.Date
  chiSoDienDau Decimal  @db.Decimal(10, 2)
  chiSoNuocDau Decimal  @db.Decimal(10, 2)
  ghiChu       String?  @db.Text

  hopDong        HopDong          @relation(fields: [maHD], references: [maHD])
  nhanVien       NhanVien         @relation(fields: [maNV], references: [maNV])
  chiTietBanGiao ChiTietBanGiao[]

  @@map("BienBanBanGiao")
}

model ChiTietBanGiao {
  maBBBG   String @db.VarChar(10)
  maTS     String @db.VarChar(10)
  maGiuong String @db.VarChar(10)
  soLuong  Int    @default(1)
  ghiChu   String? @db.Text

  bienBanBanGiao BienBanBanGiao @relation(fields: [maBBBG], references: [maBBBG])
  taiSan         TaiSan         @relation(fields: [maTS], references: [maTS])
  giuong         Giuong         @relation(fields: [maGiuong], references: [maGiuong])

  @@id([maBBBG, maTS, maGiuong])
  @@map("ChiTietBanGiao")
}

// ─── BIÊN BẢN TRẢ PHÒNG & THANH LÝ ─────────────────────────────────────────

model BienBanTraPhong {
  maBBTP         String   @id @db.VarChar(10)
  maHD           String   @db.VarChar(10)
  maNV           String   @db.VarChar(10)
  ngayTra        DateTime @db.Date
  chiSoDienCuoi  Decimal  @db.Decimal(10, 2)
  chiSoNuocCuoi  Decimal  @db.Decimal(10, 2)
  trangThaiPhong String   @db.VarChar(50)   // "Tot" | "HuHong" | "MatMat"
  ghiChu         String?  @db.Text

  hopDong   HopDong   @relation(fields: [maHD], references: [maHD])
  nhanVien  NhanVien  @relation(fields: [maNV], references: [maNV])
  khauTru   KhauTru[]
  thanhLyHD ThanhLyHD[]

  @@map("BienBanTraPhong")
}

model KhauTru {
  maKT         String  @id @db.VarChar(10)
  maBBTP       String  @db.VarChar(10)
  maTS         String  @db.VarChar(10)
  soLuong      Int     @default(1)
  chiPhiKhauTru Decimal @db.Decimal(12, 0)
  ghiChu       String? @db.Text

  bienBanTraPhong BienBanTraPhong @relation(fields: [maBBTP], references: [maBBTP])
  taiSan          TaiSan          @relation(fields: [maTS], references: [maTS])

  @@map("KhauTru")
}

model ThanhLyHD {
  maTLHD     String   @id @db.VarChar(10)
  maBBTP     String   @db.VarChar(10)
  maNV       String   @db.VarChar(10)
  ngayThanhLy DateTime @db.Date
  tienHoanCoc Decimal  @db.Decimal(12, 0)
  tienThuThem Decimal  @db.Decimal(12, 0) @default(0)
  trangThai  String   @db.VarChar(20)     // "HoanTat" | "ChoXuLy"

  bienBanTraPhong BienBanTraPhong @relation(fields: [maBBTP], references: [maBBTP])
  nhanVien        NhanVien        @relation(fields: [maNV], references: [maNV])

  @@map("ThanhLyHD")
}
